# Trakt — https://trakt.tv/oauth/applications
#
# The redirect URI must match what you set in your Trakt app. The default
# "urn:ietf:wg:oauth:2.0:oob" is the out-of-band flow — Trakt shows the code
# on a page after authorization and you copy-paste it back to the agent.

TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob

# OpenSubtitles — https://www.opensubtitles.com/consumers
#
# API_KEY identifies your app and is sent on every request.
# USERNAME / PASSWORD authenticate a real user account; the adapter exchanges
# them via POST /api/v1/login for a Bearer token, which is required on
# POST /api/v1/download.
# USER_AGENT must match the registered consumer name on the OpenSubtitles
# consumers page; generic UAs are rejected.

OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=
OPENSUBTITLES_USER_AGENT=

# OpenSubtitles bearer token — populated by `mix jido_watch.operator_setup`,
# which exchanges the credentials above for a bearer the journey test reads
# at startup. Refresh by re-running operator_setup.

OPENSUBTITLES_BEARER_TOKEN=
